# Copy this file to staging.secrets.tfvars and keep the working copy untracked.
# This file is for sensitive staging values and managed service URLs.

backend_jwt_secret = "replace-with-staging-jwt-secret"
openai_api_key     = "replace-with-staging-openai-api-key"

# Required when postgresql_enabled = false.
database_url = "postgresql+psycopg://nexora:replace-with-password@staging-postgres.example.com:5432/nexora"

# Required when redis_enabled = false.
redis_url = "redis://:replace-with-password@staging-redis.example.com:6379/0"

# Optional when you want to pin the in-cluster PostgreSQL password instead of letting Terraform generate one.
# postgresql_password = "replace-with-postgresql-password"

# Optional alternate secret name if you do not want to use OPENAI_API_KEY.
# nexora_openai_api_key = "replace-with-staging-openai-api-key"